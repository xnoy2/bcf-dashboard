APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================================
# CEO DASHBOARD INTEGRATIONS (values required — see deployment notes)
# ============================================================
APP_TIMEZONE=Europe/London

# Admin login (bcrypt hash)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# GoHighLevel private-integration tokens (pit-...) per business
BCF_GHL_API_KEY=
BCF_LOCATION_ID=
BGR_GHL_API_KEY=
BGR_LOCATION_ID=
RG_GHL_API_KEY=
RG_LOCATION_ID=

# Cloudflare (zone read + DNS read)
CF_API_TOKEN=

# Live portals
BCF_PORTAL_URL=
BCF_PORTAL_API_KEY=
BGR_PORTAL_URL=
BGR_PORTAL_TOKEN=
STAFF_PORTAL_URL=
STAFF_PORTAL_TOKEN=

# GoDaddy (sso-key KEY:SECRET) — up to three accounts
GODADDY_1_LABEL=
GODADDY_1_KEY=
GODADDY_1_SECRET=
GODADDY_2_LABEL=
GODADDY_2_KEY=
GODADDY_2_SECRET=
GODADDY_3_LABEL=
GODADDY_3_KEY=
GODADDY_3_SECRET=

# Domain renewal alerts
RENEWAL_ALERT_DAYS=10
RENEWAL_ALERT_EMAILS=

# Read-only integration API. Set to a long random secret to enable /api/v1/*.
# Leave empty to disable the API (all requests return 503). Generate with:
#   php -r 'echo "bcf_live_".bin2hex(random_bytes(24));'
DASHBOARD_API_KEY=

# Board card attachments. ATTACHMENTS_DISK=boards (local, needs a Railway volume)
# or r2 (Cloudflare R2 — big files via presigned upload/download, no volume).
ATTACHMENTS_DISK=boards
ATTACHMENTS_MAX_MB=500
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# GoHighLevel agency OAuth app (multi-sub-account integration). GHL_VERSION_ID
# is the app version id (Draft apps authorise by version_id, not client_id).
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_VERSION_ID=
GHL_REDIRECT_PATH=/integrations/crm/callback
